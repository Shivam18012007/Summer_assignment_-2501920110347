    scanf("%d",&num);
    originalnum=num;
     while(num!=0){
        digit=num%10;
        rev=10*rev+digit;
        num=num/10;
    
     }
     if(originalnum==rev){
        printf("%d  is palindrome",originalnum);
     }
     else{
        printf("%d  is not palindrome",originalnum);
     }

