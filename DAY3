#include<stdio.h>
int main(){
    int n,isprime=1,i;
    printf("enter the number");
    scanf("%d",&n);

    for(i=2;i<n;i++){

        if(n%i==0){
            isprime=0;
            break;
        }
    }
    if(isprime){
        printf("prime");
    }
    else{
        printf("not prime");
    }
    return 0;
}



QUESTION 10


#include<stdio.h>
int main(){
    int start,end,i,j,isprime;

    printf("enter the starting number:");
    scanf("%d",&start);

    printf("enter the ending number");
    scanf("%d",&end);

    for(i=start;i<=end;i++){
        if(i<2)
        continue;
        isprime=1;

        for(j=2;j*j<=i;j++)
        if(i%j==0){
            isprime=0;
            break;
        }
    }
    if(isprime){
        printf("%d",i);
    }
    return 0;
}




QUESTION 11

#include<stdio.h>
int gcd(int a,int b){
    if(b==0)
    return a;
    else
    return gcd(b,a%b);
}
int main(){
    int num1,num2;
    printf("enter two numbers");
    scanf("%d%d",&num1,&num2);

    int result=gcd(num1,num2);
    printf("gcd of %d and %d is:%d\n",num1,num2,result);
    return 0;
}



