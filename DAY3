#include <stdio.h>
int main(){
    int a,b,temp1,temp2,gcd,lcm;
    printf("enter two numbers:");
    scanf("%d%d",&a,&b);

    temp1=a;
    temp2=b;

    while(temp2!=0){
        int rem=temp1%temp2;
        temp1=temp2;
        temp2=rem;
    }
    gcd=temp1;
    lcm=a*b/gcd;
    printf("lcm=%d\n",lcm);
    return 0;
}
