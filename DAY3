#include<stdio.h>
int main(){
    int n,isprime=1,i;
    printf("enter the number");
    scanf("%d",&n);

    for(i=2;i<n;i++){

        if(n%i==0){
            isprime=0;
            break;
        }
    }
    if(isprime){
        printf("prime");
    }
    else{
        printf("not prime");
    }
    return 0;
}
